---
import Button from "../ui/Button.astro";
import Heading from "../ui/Heading.astro";
import Tools from "../portfolio/Tools.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const [staticData] = await getCollection("staticData");
const {
  profileAlt,
  profileLink,
  profileImage,
  profileName,
  profileTitle,
  email,
  emailIconName,
  github,
  portfolioImage,
  contactSectionButtonText,
  cvLink,
} = staticData.data;
---

<section
  class="scroll-m-16 px-8 max-sm:px-4 py-12"
  id="home"
  aria-label="Professional profile and introduction"
>
  <!-- Main Hero Card -->
  <div
    class="mx-auto mb-6 min-h-[26rem] w-full max-w-7xl rounded-3xl bg-gradient-to-r from-mint-300/80 dark:from-mint-600/60 to-mint-100/50 dark:to-mint-200/5 p-[2px] shadow-xl shadow-mint-500/5 dark:shadow-mint-400/5 hover:shadow-2xl hover:shadow-mint-500/10 transition-shadow duration-500"
  >
    <div
      class="group relative z-0 flex h-full items-center justify-center gap-10 overflow-hidden rounded-3xl bg-gradient-to-tr from-riptide-50 to-white p-8 transition-all duration-500 dark:bg-gradient-to-r dark:from-mint-950 dark:to-zinc-950 max-md:w-full max-md:gap-4 max-lg:gap-6 max-sm:flex-col max-sm:p-6
      dark:before:bg-[radial-gradient(circle,rgba(13,188,130,0.4)_0,rgba(1,45,34,0.2)_100%)] before:bg-[radial-gradient(circle,rgba(95,255,202,0.5)_0,rgba(144,253,210,0.3)_100%)] before:absolute before:left-65 before:top-10 before:h-[45%] before:aspect-square before:rounded-full before:blur-3xl before:opacity-60 before:-z-10 before:transition-all before:duration-700 hover:before:opacity-100 hover:before:scale-110"
    >
      <!-- Profile Image -->
      <div class="w-52 h-52 md:w-72 md:h-72 lg:w-80 lg:h-80 max-sm:w-36 max-sm:h-36 flex-shrink-0">
        <div
          class="group-hover:scale-105 relative z-10 flex w-full cursor-pointer items-center overflow-hidden rounded-full p-[3px] transition-all duration-500 bg-gradient-to-br from-riptide-400 to-mint-400 dark:from-riptide-500 dark:to-mint-500 shadow-lg shadow-mint-400/20"
        >
          <div class="relative z-20 flex w-full rounded-full bg-mint-900 overflow-hidden">
            <a
              href={profileLink}
              class="flex h-full w-full"
              aria-label="Ver página acerca de mí"
            >
              <img
                src={profileImage}
                alt={profileAlt}
                class="w-full aspect-square rounded-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="eager"
              />
            </a>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div
        class="flex h-full w-7/12 flex-col justify-center gap-5 p-4 max-md:w-full max-md:gap-3 max-sm:text-center"
      >
        <!-- Availability Badge -->
        <span
          class="inline-flex items-center gap-2 text-sm font-semibold dark:text-white text-blacktext max-sm:justify-center"
        >
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
          </span>
          Disponible para trabajar
        </span>

        <!-- Name -->
        <h1
          class="text-5xl font-black leading-tight text-blacktext dark:text-white max-xl:text-4xl max-lg:text-3xl max-sm:text-2xl"
        >
          {profileName} <span class="inline-block animate-bounce">👋</span>
        </h1>

        <!-- Description -->
        <div class="space-y-3">
          <p
            class="text-2xl font-bold bg-gradient-to-r from-riptide-500 to-mint-500 bg-clip-text text-transparent dark:from-riptide-300 dark:to-mint-200 max-xl:text-xl max-lg:text-lg"
          >
            Full-Stack Developer
          </p>
          <p
            class="text-base leading-relaxed text-blacktext/80 dark:text-gray-300 max-xl:text-sm max-w-2xl"
          >
            Estudiante de <strong class="text-blacktext dark:text-white">Ingeniería Civil Informática</strong> en la Universidad Católica de Temuco con <strong class="text-mint-600 dark:text-mint-300">4 años de experiencia</strong> en desarrollo Full‑Stack. Especializado en TypeScript, React, Astro, Node.js (NestJS/Express), Python y Rust. Apasionado por la <strong class="text-blacktext dark:text-white">Arquitectura Limpia</strong> y el diseño de software escalable.
          </p>
        </div>

        <!-- CTA Buttons -->
        <div class="flex gap-3 pt-2 max-sm:flex-col max-sm:items-center">
          <Button
            link={"mailto:" + email}
            text={contactSectionButtonText ?? "Contactar"}
            iconName={emailIconName}
          />
          <Button
            link="#projects"
            text="Ver proyectos"
            iconName="code"
          />
          <Button
            link="/images/projects/CVBenjamínEspinoza.pdf"
            text="Descargar CV"
            iconName="paperplane"
            isExternal={true}
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Tools Section -->
  <div
    class="mx-auto grid max-w-7xl grid-cols-1 gap-4 max-sm:gap-3"
  >
    <div
      class="col-span-1 rounded-3xl bg-gradient-to-r from-mint-300/60 dark:from-mint-600/40 to-mint-100/30 dark:to-mint-200/5 p-[2px] shadow-lg shadow-mint-500/5"
    >
      <article
        class="group relative z-0 flex h-full w-full flex-col overflow-hidden rounded-3xl bg-gradient-to-tr from-riptide-50 to-mint-50 p-8 transition-all duration-500 dark:bg-gradient-to-r dark:from-mint-900/80 dark:to-mint-950 max-md:p-5 gap-6
        dark:before:bg-[radial-gradient(circle,rgba(13,188,130,0.3)_0,rgba(1,45,34,0.1)_100%)] before:bg-[radial-gradient(circle,rgba(95,255,202,0.4)_0,rgba(144,253,210,0.2)_100%)] before:absolute before:left-30 before:-bottom-0 before:h-[70%] before:aspect-square before:rounded-full before:blur-3xl before:opacity-30 dark:before:opacity-50 before:-z-10 before:transition-all before:duration-500 hover:before:opacity-50 dark:hover:before:opacity-70"
      >
        <div class="flex items-center gap-4 max-md:gap-3">
          <div class="p-3 rounded-xl bg-mint-200/50 dark:bg-mint-800/30">
            <Icon
              class="text-3xl dark:text-mint-300 text-mint-600 max-md:text-2xl"
              name="dashboard"
              aria-hidden="true"
            />
          </div>
          <Heading textGradient="Tecnologías que domino" level={3} />
        </div>
        <div class="overflow-y-auto max-h-[300px] pr-2">
          <Tools />
        </div>
      </article>
    </div>
  </div>
</section>

---
import Project from "./Project.astro";
import Heading from "../ui/Heading.astro";
import { Icon } from "astro-icon/components";

const allPosts = await Astro.glob("../../pages/portfolio/projects/*.md");

// Sort by descending date (most recent first)
allPosts.sort(
  (a, b) =>
    new Date(b.frontmatter.pubDate).getTime() -
    new Date(a.frontmatter.pubDate).getTime(),
);
---

<section
  class="bg-gradient-to-t dark:from-[#0e0e10] from-white from-50% to-transparent to-100% scroll-m-16 relative pt-16 pb-32 max-2xl:px-8 max-md:pt-8"
  id="projects"
>
  <div class="mx-auto max-w-7xl py-8">
    <!-- Section Header -->
    <div class="flex flex-col items-center justify-center text-center gap-4 mb-12">
      <div class="flex gap-4 items-center">
        <div class="p-3 rounded-xl bg-mint-200/50 dark:bg-mint-800/30">
          <Icon class="text-2xl dark:text-mint-300 text-mint-600" name="code" />
        </div>
        <Heading text="Proyectos" textGradient="Realizados" level={2} />
      </div>

      <p
        class="z-2 text-center mx-auto text-lg max-xl:text-base max-w-2xl dark:text-gray-300 text-blacktext/80 leading-relaxed font-medium"
      >
        Aquí muestro algunos de los <span
          class="bg-gradient-to-r from-riptide-500 to-mint-500 dark:from-riptide-300 dark:to-mint-200 text-transparent bg-clip-text font-bold"
          >proyectos</span
        > en los que he trabajado, aplicando nuevas tecnologías y mejores prácticas de desarrollo.
      </p>
    </div>
    <slot />
  </div>

  <!-- Projects Grid -->
  <div
    id="containerProjects"
    class="mx-auto max-w-7xl grid grid-cols-3 max-lg:grid-cols-2 max-md:grid-cols-1 gap-6 p-2 py-4 max-h-[150vh] overflow-hidden transition-[max-height] duration-500 ease-in-out"
  >
    {
      allPosts.map((post) => (
        <Project
          url={post.url}
          title={post.frontmatter.title}
          description={post.frontmatter.description}
          date={post.frontmatter.pubDate}
          languages={post.frontmatter.languages}
          image={post.frontmatter.image}
        />
      ))
    }
  </div>

  <!-- Load More Button -->
  <div
    id="moreProjects"
    class="w-full flex justify-center text-center bg-gradient-to-t from-[#FBFEFD] dark:from-[#0e0e10] from-55% to-transparent to-100% py-8 mt-4"
  >
    <button
      id="moreProjectsBtn"
      aria-controls="containerProjects"
      aria-expanded="false"
      class="group flex items-center gap-2 font-bold cursor-pointer text-mint-500 dark:text-mint-300 hover:text-mint-600 dark:hover:text-mint-200 transition-all duration-300 px-6 py-3 rounded-full border border-mint-300/50 dark:border-mint-600/50 hover:border-mint-400 dark:hover:border-mint-400 hover:bg-mint-50 dark:hover:bg-mint-900/20"
      type="button"
    >
      <span>Ver más proyectos</span>
      <svg class="w-5 h-5 group-hover:translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </button>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.querySelector('#containerProjects');
    const btn = document.querySelector('#moreProjectsBtn');

    if (!container || !btn) return;

    btn.addEventListener('click', () => {
      // Remove the collapsed constraints so the container can grow
      container.classList.remove('max-h-[150vh]');
      container.classList.remove('overflow-hidden');

      // Animate using inline maxHeight based on scrollHeight to avoid sudden jump
      const full = container.scrollHeight;
      container.style.maxHeight = full + 'px';

      // After animation, clear the inline maxHeight so layout is natural
      setTimeout(() => {
        container.style.maxHeight = '';
      }, 520);

      // Accessibility + hide the button
      btn.setAttribute('aria-expanded', 'true');
      btn.classList.add('hidden');

      // Ensure footer gets pushed down and user sees the newly revealed content
      setTimeout(() => {
        try {
          container.scrollIntoView({ behavior: 'smooth', block: 'end' });
        } catch (e) {
          window.scrollTo({ top: container.offsetTop + container.scrollHeight - window.innerHeight + 16, behavior: 'smooth' });
        }
      }, 600);
    });
  });
</script>

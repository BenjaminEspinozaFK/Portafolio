---
// Organized tools by category for better visual presentation
const toolCategories = {
  "Frontend": ["html", "javascript", "ts", "react", "angular", "astro", "svelte", "vite"],
  "Backend": ["node", "express", "nestjs", "python", "rust"],
  "Estilos": ["css", "tailwind", "bootstrap"],
  "Bases de Datos": ["mongo", "firebase", "mysql", "postgresql", "prisma", "redis", "jwt"],
  "DevOps & Tools": ["docker", "git", "github", "linux", "nginx", "vercel", "pnpm"],
  "Otros": ["figma", "markdown", "php", "wordpress"]
};

// Flat list for default variant
const allTools = Object.values(toolCategories).flat();

import Capsule from "../ui/Capsule.astro";

type ToolVariant = "default" | "center" | "categorized";

// Base classes that are common to all variants
const baseClasses = "flex flex-wrap gap-3 max-lg:gap-2";

// Variant-specific classes
const variantClasses: Record<ToolVariant, string> = {
  default: "cursor-default",
  center: "justify-center cursor-default",
  categorized: "cursor-default"
};

const { variant = "default", linkEnabled = false, size = "md" } = Astro.props;

// Combine base classes with variant-specific classes
const classes = `${baseClasses} ${variantClasses[variant as ToolVariant]}`;
---

{variant === "categorized" ? (
  <div class="space-y-6">
    {Object.entries(toolCategories).map(([category, tools]) => (
      <div class="space-y-3">
        <h4 class="text-sm font-semibold text-mint-500 dark:text-mint-400 uppercase tracking-wider">
          {category}
        </h4>
        <div class={classes}>
          {tools.map((tool) => <Capsule lang={tool} linkEnabled={linkEnabled} size={size} />)}
        </div>
      </div>
    ))}
  </div>
) : (
  <div class={classes}>
    {allTools.map((tool) => <Capsule lang={tool} linkEnabled={linkEnabled} size={size} />)}
  </div>
)}

---
import Social from "../ui/Social.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const [staticData] = await getCollection("staticData");
const {
  github,
  alias,
  instagram,
  email,
  youtube,
  linkedin,
  emailIconName,
  youtubeIconName,
  linkedinIconName,
  instagramIconName,
  githubIconName,
  profileName,
} = staticData.data;

const currentYear = new Date().getFullYear();
---

<footer
  class="relative bottom-0 w-full px-4 py-12 font-medium text-blacktext dark:bg-gradient-to-t dark:from-zinc-950 dark:to-transparent border-t border-mint-200/20 dark:border-zinc-800 dark:text-zinc-300"
  role="contentinfo"
  aria-label="Site footer"
>
  <div
    class="mx-auto flex max-w-7xl flex-col items-center justify-center gap-8 max-xl:px-6"
  >
    <!-- Logo/Brand -->
    <a 
      href="/" 
      aria-label="Return to homepage" 
      class="group flex items-center gap-2 font-bold text-xl hover:text-mint-400 transition-all duration-300"
    >
      <span class="relative">
        <span class="bg-gradient-to-r from-riptide-400 to-mint-400 bg-clip-text text-transparent group-hover:from-riptide-300 group-hover:to-mint-300 transition-all">
          {profileName || alias}
        </span>
        <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-gradient-to-r from-riptide-400 to-mint-400 group-hover:w-full transition-all duration-300"></span>
      </span>
      <Icon name="rocket" class="text-mint-400 group-hover:rotate-12 transition-transform duration-300" />
    </a>

    <!-- Divider -->
    <div class="w-24 h-px bg-gradient-to-r from-transparent via-mint-400/50 to-transparent"></div>

    <!-- Social Links -->
    <nav
      class="flex items-center justify-center gap-6 text-2xl"
      role="navigation"
      aria-label="Social media links"
    >
      <Social
        link={`mailto:${email}`}
        iconName={emailIconName}
        label={`Send email to ${email}`}
      />
      <Social
        link={instagram}
        iconName={instagramIconName}
        label={`Visit ${alias} on Instagram`}
      />
      <Social
        link={youtube}
        iconName={youtubeIconName}
        label={`Visit ${alias} on YouTube`}
      />
      <Social
        link={github}
        iconName={githubIconName}
        label={`Visit ${alias} on GitHub`}
      />
      <Social
        link={linkedin}
        iconName={linkedinIconName}
        label={`Visit ${alias} on LinkedIn`}
      />
    </nav>

    <!-- Copyright & Credits -->
    <div class="flex flex-col items-center gap-2 text-sm text-zinc-500 dark:text-zinc-500">
      <p>
        © {currentYear} <span class="text-mint-500 dark:text-mint-400 font-medium">{profileName || alias}</span>. Todos los derechos reservados.
      </p>
      <p class="flex items-center gap-1">
        Hecho con <Icon name="astro" class="text-orange-500 size-4" aria-hidden="true" /> Astro y mucho <span class="text-red-400">♥</span>
      </p>
    </div>
  </div>
</footer>

---
interface Props {
    text?: string;
    textGradient?: string;
    level?: 1 | 2 | 3;
    className?: string;
}

const { text = "", textGradient = "", level = 1, className = "" } = Astro.props;

const Tag = `h${level}`;

const sizeClasses = {
    1: "text-5xl max-xl:text-4xl max-md:text-3xl",
    2: "text-4xl max-xl:text-3xl max-md:text-2xl",
    3: "text-3xl max-xl:text-2xl max-md:text-xl"
};
---

<Tag class:list={[
    "font-extrabold tracking-tight",
    sizeClasses[level],
    "dark:text-white text-blacktext",
    className
]}>
    {text && (
        <>
            {text}
            {textGradient && " "}
        </> 
    )}
    {textGradient && (
        <span
            class="bg-gradient-to-r from-riptide-400 to-mint-400 dark:from-riptide-400 dark:to-mint-400 text-transparent bg-clip-text"
        >{textGradient}</span>
    )}
</Tag> 
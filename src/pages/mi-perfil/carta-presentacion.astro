---
import Layout from "/src/layouts/Layout.astro";

const meses = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
const fecha = new Date();
const fechaFormateada = `Temuco, ${meses[fecha.getMonth()]} ${fecha.getFullYear()}`;
---

<Layout
  pageTitle="Carta de Presentación | Benjamin Espinoza"
  description="Carta de presentación profesional para presentar mis competencias y experiencia como desarrollador Full Stack."
>
  <section class="min-h-screen px-6 py-16 max-sm:py-12">
    <div class="max-w-4xl mx-auto">

      <!-- Header -->
      <div class="text-center mb-16 max-sm:mb-12">
        <h1 class="text-5xl max-sm:text-3xl font-bold mb-4">
          <span class="bg-gradient-to-r from-riptide-400 to-mint-300 bg-clip-text text-transparent">Carta de Presentación</span>
        </h1>
        <p class="text-lg text-zinc-400">Profesional y personalizable</p>
      </div>

      <!-- Carta -->
      <div class="relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-mint-400 to-riptide-400 rounded-3xl blur-2xl opacity-20"></div>

        <div id="cartaContent" class="relative bg-gradient-to-br from-zinc-900 to-zinc-950 border border-mint-400/30 rounded-3xl p-16 max-sm:p-8 shadow-2xl">

          <!-- Fecha y datos -->
          <div class="mb-8 text-right">
            <p class="text-sm text-zinc-400">{fechaFormateada}</p>
          </div>

          <!-- Saludo -->
          <p class="text-lg text-zinc-300 mb-8">A quien corresponda,</p>

          <!-- Párrafo 1 - Presentación -->
          <div class="mb-6 p-6 border-l-4 border-riptide-400 bg-riptide-500/5 rounded">
            <p class="text-base leading-relaxed text-zinc-300">
              Me dirijo a usted para presentarme como candidato para la posición de <span class="font-bold text-white">Desarrollador Full Stack / Especialista en Automatización de Procesos</span> en su organización.
            </p>
          </div>

          <!-- Párrafo 2 - Mi perfil -->
          <div class="mb-8">
            <p class="text-base leading-relaxed text-zinc-300 mb-6">
              Soy <span class="font-bold text-white">Benjamin Espinoza</span>, estudiante de quinto año de <span class="font-bold text-mint-300">Ingeniería Civil Informática</span> en la Universidad Católica de Temuco, con más de <span class="font-bold text-mint-300">4 años de experiencia</span> en desarrollo web y soluciones tecnológicas. Mi especialidad radica en la <span class="font-bold text-riptide-300">automatización de procesos</span> integrada con <span class="font-bold text-riptide-300">Inteligencia Artificial</span>, creando soluciones escalables y seguras que generan valor real a las organizaciones.
            </p>

            <!-- Tecnologías en cuadro -->
            <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-lg p-6 mb-6">
              <p class="text-sm font-bold text-mint-300 uppercase tracking-wider mb-4">Stack Tecnológico</p>
              <div class="grid grid-cols-2 grid-cols-1 md:grid-cols-2 gap-3 text-sm text-zinc-300">
                <div>
                  <p class="font-semibold text-mint-300 mb-2">Frontend</p>
                  <p>React, Astro, TypeScript, Tailwind CSS</p>
                </div>
                <div>
                  <p class="font-semibold text-riptide-300 mb-2">Backend</p>
                  <p>Node.js, NestJS, Express</p>
                </div>
                <div>
                  <p class="font-semibold text-mint-300 mb-2">Bases de Datos</p>
                  <p>PostgreSQL, MySQL, Redis</p>
                </div>
                <div>
                  <p class="font-semibold text-riptide-300 mb-2">DevOps & Cloud</p>
                  <p>Docker, Vercel, Netlify</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Diferencial -->
          <div class="mb-8">
            <h3 class="text-lg font-bold text-mint-300 mb-4">¿Por Qué Me Diferencia?</h3>
            <p class="text-base leading-relaxed text-zinc-300 mb-6">
              Mi valor diferencial no es solo <span class="font-bold text-white">automatizar procesos</span>, sino <span class="font-bold text-white">integrar inteligencia artificial</span> en cada solución para que sean:
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="p-4 bg-mint-500/10 border border-mint-400/30 rounded-lg">
                <p class="font-semibold text-mint-300">Adaptables</p>
                <p class="text-xs text-zinc-400">Aprenden y mejoran continuamente</p>
              </div>
              <div class="p-4 bg-riptide-500/10 border border-riptide-400/30 rounded-lg">
                <p class="font-semibold text-riptide-300">Escalables</p>
                <p class="text-xs text-zinc-400">Crecen con necesidades de la organización</p>
              </div>
              <div class="p-4 bg-green-500/10 border border-green-400/30 rounded-lg">
                <p class="font-semibold text-green-300">Seguras</p>
                <p class="text-xs text-zinc-400">Mejores prácticas de seguridad</p>
              </div>
              <div class="p-4 bg-amber-500/10 border border-amber-400/30 rounded-lg">
                <p class="font-semibold text-amber-300">Inteligentes</p>
                <p class="text-xs text-zinc-400">Generan decisiones basadas en datos</p>
              </div>
            </div>
          </div>

          <!-- Experiencia -->
          <div class="mb-8">
            <h3 class="text-lg font-bold text-riptide-300 mb-4">Experiencia Destacada</h3>
            <ul class="space-y-2 text-base text-zinc-300 list-disc list-inside">
              <li>Desarrollo de <span class="font-semibold">arquitecturas limpias</span> y mantenibles</li>
              <li>Implementación de <span class="font-semibold">APIs REST</span> con documentación Swagger/OpenAPI</li>
              <li><span class="font-semibold">Ayudante de Diseño de Software</span> compartiendo principios SOLID y patrones</li>
              <li>Experiencia con <span class="font-semibold">testing automatizado</span> y TDD</li>
              <li>Gestión de <span class="font-semibold">proyectos ágiles</span> y trabajo colaborativo</li>
            </ul>
          </div>

          <!-- Competencias -->
          <div class="mb-8 p-6 bg-gradient-to-r from-mint-500/10 to-riptide-500/10 border border-mint-400/30 rounded-lg">
            <p class="text-sm font-bold text-mint-300 uppercase tracking-wider mb-3">Competencias Clave</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-mint-500/20 text-mint-300 rounded-full text-sm font-medium">Automatización</span>
              <span class="px-3 py-1 bg-riptide-500/20 text-riptide-300 rounded-full text-sm font-medium">Ciberseguridad</span>
              <span class="px-3 py-1 bg-purple-500/20 text-purple-300 rounded-full text-sm font-medium">IA/ML</span>
              <span class="px-3 py-1 bg-blue-500/20 text-blue-300 rounded-full text-sm font-medium">Full Stack</span>
              <span class="px-3 py-1 bg-green-500/20 text-green-300 rounded-full text-sm font-medium">Escalabilidad</span>
            </div>
          </div>

          <!-- Contacto -->
          <div class="mb-8">
            <h3 class="text-lg font-bold text-mint-300 mb-4">Contacto</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-base text-zinc-300">
              <div>
                <p class="text-sm text-zinc-400 font-semibold">Email</p>
                <a href="mailto:benjamintwo2002@gmail.com" class="text-mint-300 hover:text-mint-200 transition">benjamintwo2002@gmail.com</a>
              </div>
              <div>
                <p class="text-sm text-zinc-400 font-semibold">Teléfono</p>
                <a href="tel:+56948553479" class="text-mint-300 hover:text-mint-200 transition">+56948553479</a>
              </div>
              <div>
                <p class="text-sm text-zinc-400 font-semibold">GitHub</p>
                <a href="https://github.com/BenjaminEspinozaFK" target="_blank" rel="noopener" class="text-mint-300 hover:text-mint-200 transition">github.com/BenjaminEspinozaFK</a>
              </div>
              <div>
                <p class="text-sm text-zinc-400 font-semibold">LinkedIn</p>
                <a href="https://www.linkedin.com/in/benjamin-espinoza-52b3a6375/" target="_blank" rel="noopener" class="text-mint-300 hover:text-mint-200 transition">benjamin-espinoza-52b3a6375</a>
              </div>
            </div>
          </div>

          <!-- Cierre -->
          <div class="border-t border-zinc-700 pt-8 mt-8">
            <p class="text-base leading-relaxed text-zinc-300 mb-6">
              Busco una posición donde pueda aplicar mis habilidades en <span class="font-bold text-white">automatización e IA</span> para crear soluciones que generen impacto. Estoy comprometido con el <span class="font-bold text-white">aprendizaje continuo</span>, la <span class="font-bold text-white">calidad del código</span> y la <span class="font-bold text-white">excelencia</span> en cualquier proyecto que emprenda.
            </p>
            <p class="text-base text-zinc-300 mb-8">
              Agradezco sinceramente la consideración de mi candidatura y quedo atento a cualquier consulta adicional.
            </p>
            <div>
              <p class="text-base text-zinc-300 mb-2">Atentamente,</p>
              <p class="text-2xl font-bold text-white mt-6 mb-1">Benjamin Espinoza</p>
              <p class="text-sm text-zinc-400">Estudiante de Ingeniería Civil Informática</p>
              <p class="text-sm text-zinc-400">Universidad Católica de Temuco</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Botones de Descarga -->
      <div class="text-center mt-12 max-sm:mt-8">
        <p class="text-zinc-400 mb-6">Descarga tu carta de presentación</p>
        <div class="flex gap-4 justify-center flex-wrap">
          <button 
            id="downloadPDF"
            class="px-8 py-3 bg-gradient-to-r from-mint-600 to-mint-500 hover:from-mint-700 hover:to-mint-600 text-white rounded-lg font-semibold transition-all transform hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="pdfText">Descargar PDF</span>
          </button>
          <button 
            id="downloadPNG"
            class="px-8 py-3 bg-gradient-to-r from-riptide-600 to-riptide-500 hover:from-riptide-700 hover:to-riptide-600 text-white rounded-lg font-semibold transition-all transform hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="pngText">Descargar PNG</span>
          </button>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  import { toPng, toBlob } from 'html-to-image';
  import jsPDF from 'jspdf';

  document.addEventListener('DOMContentLoaded', () => {
    const downloadPDF = document.getElementById('downloadPDF') as HTMLButtonElement;
    const downloadPNG = document.getElementById('downloadPNG') as HTMLButtonElement;
    const pdfText = document.getElementById('pdfText') as HTMLSpanElement;
    const pngText = document.getElementById('pngText') as HTMLSpanElement;

    // Función para descargar como PDF
    downloadPDF?.addEventListener('click', async () => {
      try {
        downloadPDF.disabled = true;
        pdfText.textContent = 'Generando PDF...';

        const element = document.getElementById('cartaContent') as HTMLElement;
        if (!element) {
          throw new Error('No se encontró el elemento');
        }

        // Clonar elemento para no afectar el original
        const clone = element.cloneNode(true) as HTMLElement;
        
        // Reemplazar emojis con texto más grande y color
        const replaceEmojis = (node: HTMLElement) => {
          const walker = document.createTreeWalker(
            node,
            NodeFilter.SHOW_TEXT,
            null
          );
          
          const textNodes: Text[] = [];
          let currentNode;
          
          while (currentNode = walker.nextNode()) {
            textNodes.push(currentNode as Text);
          }
          
          textNodes.forEach((textNode) => {
            const text = textNode.textContent || '';
            // Si contiene emojis, envolver en span con estilos especiales
            if (/[\u{1F300}-\u{1F9FF}]|[\u{2600}-\u{26FF}]|[\u{2700}-\u{27BF}]/u.test(text)) {
              const span = document.createElement('span');
              span.textContent = text;
              span.style.fontSize = '1.2em';
              span.style.fontFamily = '"Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", sans-serif';
              span.style.display = 'inline-block';
              span.style.lineHeight = '1';
              textNode.parentNode?.replaceChild(span, textNode);
            }
          });
        };
        
        replaceEmojis(clone);
        
        // Crear contenedor temporal fuera de vista
        const tempContainer = document.createElement('div');
        tempContainer.style.position = 'fixed';
        tempContainer.style.left = '-9999px';
        tempContainer.style.top = '0';
        tempContainer.style.width = element.offsetWidth + 'px';
        tempContainer.appendChild(clone);
        document.body.appendChild(tempContainer);

        // Esperar a que se renderice
        await new Promise(resolve => setTimeout(resolve, 200));

        // Generar imagen PNG con html-to-image (soporta oklch)
        const dataUrl = await toPng(clone, {
          quality: 1,
          pixelRatio: 3,
          backgroundColor: '#18181b',
          cacheBust: true,
          skipFonts: true
        });
        
        // Limpiar contenedor temporal
        document.body.removeChild(tempContainer);

        // Crear PDF
        const pdf = new jsPDF({
          orientation: 'portrait',
          unit: 'mm',
          format: 'a4'
        });

        const img = new Image();
        img.src = dataUrl;
        
        await new Promise((resolve) => {
          img.onload = resolve;
        });

        // Dimensiones de página A4
        const pageWidth = 210;
        const pageHeight = 297;
        const margin = 15; // Margen de 15mm
        
        // Ancho disponible con márgenes
        const availableWidth = pageWidth - (margin * 2);
        
        // Calcular altura proporcional
        const imgWidth = availableWidth;
        const imgHeight = (img.height * imgWidth) / img.width;
        
        // Calcular cuántas páginas necesitamos
        const availablePageHeight = pageHeight - (margin * 2);
        const totalPages = Math.ceil(imgHeight / availablePageHeight);
        
        // Agregar páginas
        for (let page = 0; page < totalPages; page++) {
          if (page > 0) {
            pdf.addPage();
          }
          
          // Calcular qué parte de la imagen va en esta página
          const sourceY = (page * availablePageHeight * img.height) / imgHeight;
          const sourceHeight = Math.min(
            (availablePageHeight * img.height) / imgHeight,
            img.height - sourceY
          );
          
          // Crear un canvas temporal para esta sección
          const tempCanvas = document.createElement('canvas');
          const ctx = tempCanvas.getContext('2d');
          
          tempCanvas.width = img.width;
          tempCanvas.height = sourceHeight;
          
          if (ctx) {
            ctx.drawImage(
              img,
              0, sourceY,           // Posición de origen en la imagen
              img.width, sourceHeight, // Tamaño de origen
              0, 0,                 // Posición de destino en canvas
              img.width, sourceHeight  // Tamaño de destino
            );
            
            const pageImageData = tempCanvas.toDataURL('image/png');
            const pageImageHeight = (sourceHeight * imgWidth) / img.width;
            
            pdf.addImage(
              pageImageData,
              'PNG',
              margin,
              margin,
              imgWidth,
              pageImageHeight,
              undefined,
              'FAST'
            );
          }
        }

        pdf.save('Carta-Presentacion-Benjamin-Espinoza.pdf');

        pdfText.textContent = 'PDF descargado';
        setTimeout(() => {
          pdfText.textContent = 'Descargar PDF';
          downloadPDF.disabled = false;
        }, 2000);
      } catch (error) {
        console.error('Error al generar PDF:', error);
        alert('Error al generar PDF: ' + (error as Error).message);
        pdfText.textContent = 'Error';
        setTimeout(() => {
          pdfText.textContent = 'Descargar PDF';
          downloadPDF.disabled = false;
        }, 2000);
      }
    });

    // Función para descargar como PNG
    downloadPNG?.addEventListener('click', async () => {
      try {
        downloadPNG.disabled = true;
        pngText.textContent = 'Generando PNG...';

        const element = document.getElementById('cartaContent') as HTMLElement;
        if (!element) {
          throw new Error('No se encontró el elemento');
        }

        // Clonar elemento para no afectar el original
        const clone = element.cloneNode(true) as HTMLElement;
        
        // Reemplazar emojis con texto más grande y color
        const replaceEmojis = (node: HTMLElement) => {
          const walker = document.createTreeWalker(
            node,
            NodeFilter.SHOW_TEXT,
            null
          );
          
          const textNodes: Text[] = [];
          let currentNode;
          
          while (currentNode = walker.nextNode()) {
            textNodes.push(currentNode as Text);
          }
          
          textNodes.forEach((textNode) => {
            const text = textNode.textContent || '';
            // Si contiene emojis, envolver en span con estilos especiales
            if (/[\u{1F300}-\u{1F9FF}]|[\u{2600}-\u{26FF}]|[\u{2700}-\u{27BF}]/u.test(text)) {
              const span = document.createElement('span');
              span.textContent = text;
              span.style.fontSize = '1.2em';
              span.style.fontFamily = '"Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", sans-serif';
              span.style.display = 'inline-block';
              span.style.lineHeight = '1';
              textNode.parentNode?.replaceChild(span, textNode);
            }
          });
        };
        
        replaceEmojis(clone);
        
        // Crear contenedor temporal fuera de vista
        const tempContainer = document.createElement('div');
        tempContainer.style.position = 'fixed';
        tempContainer.style.left = '-9999px';
        tempContainer.style.top = '0';
        tempContainer.style.width = element.offsetWidth + 'px';
        tempContainer.appendChild(clone);
        document.body.appendChild(tempContainer);

        // Esperar a que se renderice
        await new Promise(resolve => setTimeout(resolve, 200));

        // Generar blob PNG con html-to-image (soporta oklch)
        const blob = await toBlob(clone, {
          quality: 1,
          pixelRatio: 3,
          backgroundColor: '#18181b',
          cacheBust: true,
          skipFonts: true
        });
        
        // Limpiar contenedor temporal
        document.body.removeChild(tempContainer);

        if (blob) {
          const url = URL.createObjectURL(blob);
          const link = document.createElement('a');
          link.download = 'Carta-Presentacion-Benjamin-Espinoza.png';
          link.href = url;
          link.click();
          URL.revokeObjectURL(url);

          pngText.textContent = 'PNG descargado';
          setTimeout(() => {
            pngText.textContent = 'Descargar PNG';
            downloadPNG.disabled = false;
          }, 2000);
        }
      } catch (error) {
        console.error('Error al generar PNG:', error);
        alert('Error al generar PNG: ' + (error as Error).message);
        pngText.textContent = 'Error';
        setTimeout(() => {
          pngText.textContent = 'Descargar PNG';
          downloadPNG.disabled = false;
        }, 2000);
      }
    });
  });
</script>

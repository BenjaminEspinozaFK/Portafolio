---
import Layout from "/src/layouts/Layout.astro";
---

<Layout
  pageTitle="Análisis FODA-MACA | Benjamin Espinoza"
  description="Mi análisis FODA-MACA: fortalezas, oportunidades, debilidades y amenazas identificadas en mi desarrollo profesional."
>
  <section class="min-h-screen px-6 py-16 max-sm:py-12">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16 max-sm:mb-12">
        <h1 class="text-5xl max-sm:text-3xl font-bold mb-4 bg-gradient-to-r from-riptide-400 to-mint-300 bg-clip-text text-transparent">
          Matriz FODA-MACA
        </h1>
        <p class="text-lg text-zinc-400 max-w-2xl mx-auto">
          Análisis estratégico de mi desarrollo profesional y plan de acción para alcanzar mis objetivos
        </p>
      </div>

      <!-- Matriz FODA 2x2 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20 max-sm:gap-4">

        <!-- FORTALEZAS -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-r from-mint-400 to-mint-500 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition"></div>
          <div class="relative bg-gradient-to-br from-mint-500/10 to-mint-600/5 border border-mint-400/30 hover:border-mint-400/60 rounded-2xl p-8 transition-all duration-300">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-3 h-3 rounded-full bg-mint-400"></div>
              <h2 class="text-2xl font-bold text-mint-300">Fortalezas</h2>
              <span class="text-sm font-semibold text-mint-400 ml-auto">MANTENER</span>
            </div>
            <div class="space-y-4">
              <div class="border-l-2 border-mint-400 pl-4">
                <h3 class="font-bold text-white mb-1">Aprendizaje Rápido</h3>
                <p class="text-sm text-zinc-400">Habilidad para aprender nuevas tecnologías y lenguajes rápidamente</p>
              </div>
              <div class="border-l-2 border-mint-400 pl-4">
                <h3 class="font-bold text-white mb-1">Dedicación</h3>
                <p class="text-sm text-zinc-400">Constancia y disciplina en los estudios y proyectos</p>
              </div>
              <div class="border-l-2 border-mint-400 pl-4">
                <h3 class="font-bold text-white mb-1">Trabajo en Equipo</h3>
                <p class="text-sm text-zinc-400">Capacidad de colaborar efectivamente en proyectos académicos</p>
              </div>
              <div class="border-l-2 border-mint-400 pl-4">
                <h3 class="font-bold text-white mb-1">Pensamiento Analítico</h3>
                <p class="text-sm text-zinc-400">Capacidad para resolver problemas complejos</p>
              </div>
            </div>
          </div>
        </div>

        <!-- OPORTUNIDADES -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-r from-riptide-400 to-riptide-500 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition"></div>
          <div class="relative bg-gradient-to-br from-riptide-500/10 to-riptide-600/5 border border-riptide-400/30 hover:border-riptide-400/60 rounded-2xl p-8 transition-all duration-300">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-3 h-3 rounded-full bg-riptide-400"></div>
              <h2 class="text-2xl font-bold text-riptide-300">Oportunidades</h2>
              <span class="text-sm font-semibold text-riptide-400 ml-auto">APROVECHAR</span>
            </div>
            <div class="space-y-4">
              <div class="border-l-2 border-riptide-400 pl-4">
                <h3 class="font-bold text-white mb-1">Becas de Estudio</h3>
                <p class="text-sm text-zinc-400">Programas de postgrado disponibles</p>
              </div>
              <div class="border-l-2 border-riptide-400 pl-4">
                <h3 class="font-bold text-white mb-1">Plataformas Online</h3>
                <p class="text-sm text-zinc-400">Coursera, GitHub, YouTube, LinkedIn Learning</p>
              </div>
              <div class="border-l-2 border-riptide-400 pl-4">
                <h3 class="font-bold text-white mb-1">Open Source</h3>
                <p class="text-sm text-zinc-400">Contribuir a proyectos de automatización e IA</p>
              </div>
              <div class="border-l-2 border-riptide-400 pl-4">
                <h3 class="font-bold text-white mb-1">Demanda Tech</h3>
                <p class="text-sm text-zinc-400">Alta demanda de especialistas Full Stack + IA</p>
              </div>
            </div>
          </div>
        </div>

        <!-- DEBILIDADES -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-r from-red-400 to-orange-500 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition"></div>
          <div class="relative bg-gradient-to-br from-red-500/10 to-orange-600/5 border border-red-400/30 hover:border-red-400/60 rounded-2xl p-8 transition-all duration-300">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <h2 class="text-2xl font-bold text-red-300">Debilidades</h2>
              <span class="text-sm font-semibold text-red-400 ml-auto">CORREGIR</span>
            </div>
            <div class="space-y-4">
              <div class="border-l-2 border-red-400 pl-4">
                <h3 class="font-bold text-white mb-1">Inglés Intermedio</h3>
                <p class="text-sm text-zinc-400">Limita acceso a documentación técnica avanzada</p>
              </div>
              <div class="border-l-2 border-red-400 pl-4">
                <h3 class="font-bold text-white mb-1">Presentación Pública</h3>
                <p class="text-sm text-zinc-400">Falta de habilidades para exponer ideas en público</p>
              </div>
              <div class="border-l-2 border-red-400 pl-4">
                <h3 class="font-bold text-white mb-1">Concentración Prolongada</h3>
                <p class="text-sm text-zinc-400">Dificultad manteniendo hasta prolongado de tiempo</p>
              </div>
              <div class="border-l-2 border-red-400 pl-4">
                <h3 class="font-bold text-white mb-1">Portfolio Limitado</h3>
                <p class="text-sm text-zinc-400">Necesita más proyectos que demuestren expertise</p>
              </div>
            </div>
          </div>
        </div>

        <!-- AMENAZAS -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-r from-slate-600 to-slate-700 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition"></div>
          <div class="relative bg-gradient-to-br from-slate-600/10 to-slate-700/5 border border-slate-500/30 hover:border-slate-500/60 rounded-2xl p-8 transition-all duration-300">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-3 h-3 rounded-full bg-slate-400"></div>
              <h2 class="text-2xl font-bold text-slate-300">Amenazas</h2>
              <span class="text-sm font-semibold text-slate-400 ml-auto">AFRONTAR</span>
            </div>
            <div class="space-y-4">
              <div class="border-l-2 border-slate-400 pl-4">
                <h3 class="font-bold text-white mb-1">Alta Competencia</h3>
                <p class="text-sm text-zinc-400">Muchos profesionales y egresados en el mercado</p>
              </div>
              <div class="border-l-2 border-slate-400 pl-4">
                <h3 class="font-bold text-white mb-1">Automatización Tech</h3>
                <p class="text-sm text-zinc-400">Tecnología reemplazando trabajos tradicionales</p>
              </div>
              <div class="border-l-2 border-slate-400 pl-4">
                <h3 class="font-bold text-white mb-1">Costos Educación</h3>
                <p class="text-sm text-zinc-400">Los estudios son cada vez más caros</p>
              </div>
              <div class="border-l-2 border-slate-400 pl-4">
                <h3 class="font-bold text-white mb-1">Saturación Generalists</h3>
                <p class="text-sm text-zinc-400">Mercado saturado de desarrolladores genéricos</p>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Plan de Acción -->
      <div class="mt-24 max-sm:mt-16">
        <h2 class="text-4xl max-sm:text-2xl font-bold text-center mb-16 max-sm:mb-12 bg-gradient-to-r from-mint-300 to-riptide-300 bg-clip-text text-transparent">
          Plan de Acción
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-sm:gap-6">

          <!-- Corto Plazo -->
          <div class="group relative">
            <div class="absolute inset-0 bg-gradient-to-r from-green-400 to-emerald-500 rounded-xl blur-lg opacity-20 group-hover:opacity-30 transition"></div>
            <div class="relative bg-gradient-to-br from-green-500/10 to-emerald-600/5 border border-green-400/30 rounded-xl p-6 max-sm:p-5">
              <div class="flex items-center gap-2 mb-6">
                <h3 class="text-xl font-bold text-green-300">Corto Plazo</h3>
              </div>
              <p class="text-xs text-green-400/70 font-semibold mb-4">3-6 MESES</p>
              <ul class="space-y-3 list-disc list-inside text-sm text-zinc-300">
                <li>Mejorar inglés a nivel B2</li>
                <li>Crear 2-3 proyectos de automatización con IA</li>
                <li>Grabar 5 pitch presentations</li>
                <li>Contribuir a 2 proyectos open source</li>
              </ul>
            </div>
          </div>

          <!-- Mediano Plazo -->
          <div class="group relative">
            <div class="absolute inset-0 bg-gradient-to-r from-riptide-400 to-purple-500 rounded-xl blur-lg opacity-20 group-hover:opacity-30 transition"></div>
            <div class="relative bg-gradient-to-br from-riptide-500/10 to-purple-600/5 border border-riptide-400/30 rounded-xl p-6 max-sm:p-5">
              <div class="flex items-center gap-2 mb-6">
                <h3 class="text-xl font-bold text-riptide-300">Mediano Plazo</h3>
              </div>
              <p class="text-xs text-riptide-400/70 font-semibold mb-4">6-12 MESES</p>
              <ul class="space-y-3 list-disc list-inside text-sm text-zinc-300">
                <li>Obtener certificación en Machine Learning</li>
                <li>Publicar artículos técnicos sobre automatización</li>
                <li>Hablar en 1-2 conferencias o meetups</li>
                <li>Construir red de contactos en tech</li>
              </ul>
            </div>
          </div>

          <!-- Largo Plazo -->
          <div class="group relative">
            <div class="absolute inset-0 bg-gradient-to-r from-yellow-400 to-amber-500 rounded-xl blur-lg opacity-20 group-hover:opacity-30 transition"></div>
            <div class="relative bg-gradient-to-br from-yellow-500/10 to-amber-600/5 border border-yellow-400/30 rounded-xl p-6 max-sm:p-5">
              <div class="flex items-center gap-2 mb-6">
                <h3 class="text-xl font-bold text-yellow-300">Largo Plazo</h3>
              </div>
              <p class="text-xs text-yellow-400/70 font-semibold mb-4">1-2 AÑOS</p>
              <ul class="space-y-3 list-disc list-inside text-sm text-zinc-300">
                <li>Ser referencia en automatización + IA</li>
                <li>Liderar proyectos de escala empresarial</li>
                <li>Mentorizar a otros desarrolladores</li>
                <li>Contribuir a comunidades tech</li>
              </ul>
            </div>
          </div>

        </div>
      </div>

      <!-- Quote Final -->
      <div class="mt-20 max-sm:mt-12 text-center">
        <div class="max-w-3xl mx-auto p-8 max-sm:p-6 border-l-4 border-riptide-400 bg-gradient-to-r from-riptide-500/10 to-mint-500/5 rounded-lg">
          <p class="text-xl max-sm:text-lg text-zinc-300 italic font-light">
            "El análisis FODA no es un destino, es una brújula para el crecimiento continuo."
          </p>
        </div>
      </div>

    </div>
  </section>
</Layout>

---
import Layout from "/src/layouts/Layout.astro";
---

<Layout
  pageTitle="Tarjeta de Presentación | Benjamin Espinoza"
  description="Tarjeta de presentación digital - Benjamin Espinoza, Desarrollador Full Stack especializado en automatización e IA"
>
<section class="min-h-screen bg-gradient-to-b from-mint-900 to-mint-950 dark:from-mint-950 dark:to-zinc-950 flex items-center justify-center px-4 py-12">
  <div class="max-w-2xl w-full space-y-8">
    <!-- Tarjeta Digital -->
    <div class="group" id="businessCard">
      <div class="bg-gradient-to-br from-riptide-400 to-mint-300 dark:from-riptide-500 dark:to-mint-400 p-[3px] rounded-2xl shadow-2xl transition-all duration-500 hover:shadow-riptide-500/50">
        <div class="bg-mint-900 dark:bg-zinc-900 rounded-2xl p-12 space-y-8">

          <!-- Header -->
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-2xl font-bold text-white">Benjamin Espinoza</h2>
              <p class="text-riptide-300 font-semibold text-sm">Full Stack Developer</p>
            </div>
            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-riptide-400 to-mint-400 p-[2px]">
              <img src="/images/berserk.jpg" alt="Benjamin Espinoza" class="w-full h-full rounded-full object-cover" />
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px bg-gradient-to-r from-transparent via-riptide-400 to-transparent"></div>

          <!-- Especialidad -->
          <div>
            <p class="text-xs text-zinc-400 uppercase tracking-widest font-semibold">Especialidad</p>
            <p class="text-mint-200 font-semibold mt-1">Automatización de Procesos + IA</p>
          </div>

          <!-- Competencias -->
          <div>
            <p class="text-xs text-zinc-400 uppercase tracking-widest font-semibold mb-2">Competencias</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-riptide-500/20 text-riptide-300 rounded-full text-xs font-medium">Automatización</span>
              <span class="px-3 py-1 bg-mint-500/20 text-mint-300 rounded-full text-xs font-medium">IA/ML</span>
              <span class="px-3 py-1 bg-riptide-500/20 text-riptide-300 rounded-full text-xs font-medium">Full Stack</span>
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px bg-gradient-to-r from-transparent via-riptide-400 to-transparent"></div>

          <!-- Contacto -->
          <div class="space-y-3">
            <p class="text-xs text-zinc-400 uppercase tracking-widest font-semibold">Contacto</p>
            <div class="text-sm space-y-2">
              <p class="flex items-center gap-2 text-mint-200">
                <span class="text-riptide-400">📧</span>
                benjamintwo2002@gmail.com
              </p>
              <p class="flex items-center gap-2 text-mint-200">
                <span class="text-riptide-400">📱</span>
                +56948553479
              </p>
              <p class="flex items-center gap-2 text-mint-200">
                <span class="text-riptide-400">📍</span>
                Temuco, La Araucanía
              </p>
            </div>
          </div>

          <!-- Links Sociales -->
          <div class="flex gap-3 pt-2">
            <a href="https://github.com/BenjaminEspinozaFK" target="_blank" rel="noopener" class="flex items-center justify-center w-10 h-10 rounded-lg bg-zinc-800 hover:bg-riptide-500 transition-colors text-mint-300 hover:text-white">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/benjamin-espinoza-52b3a6375/" target="_blank" rel="noopener" class="flex items-center justify-center w-10 h-10 rounded-lg bg-zinc-800 hover:bg-riptide-500 transition-colors text-mint-300 hover:text-white">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
            <a href="mailto:benjamintwo2002@gmail.com" class="flex items-center justify-center w-10 h-10 rounded-lg bg-zinc-800 hover:bg-riptide-500 transition-colors text-mint-300 hover:text-white">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Opciones de Descarga -->
    <div class="text-center space-y-3">
      <p class="text-mint-300 text-sm font-semibold">Descarga tu versión</p>
      <div class="flex gap-3 justify-center flex-wrap">
        <button 
          id="downloadPDF"
          class="px-6 py-2 bg-riptide-500 hover:bg-riptide-600 text-white rounded-lg text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="pdfText">📥 PDF</span>
        </button>
        <button 
          id="downloadPNG"
          class="px-6 py-2 bg-mint-600 hover:bg-mint-700 text-white rounded-lg text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="pngText">🖼️ PNG</span>
        </button>
        <button 
          id="copyContact"
          class="px-6 py-2 bg-zinc-700 hover:bg-zinc-600 text-white rounded-lg text-sm font-semibold transition-colors"
        >
          <span id="copyText">📋 Copiar</span>
        </button>
      </div>
    </div>

    <!-- Info adicional -->
    <div class="text-center text-xs text-zinc-400 space-y-2">
      <p>Ingeniero Civil Informático | Universidad Católica de Temuco</p>
      <p class="text-riptide-400 font-semibold">Especialista en Automatización + IA</p>
    </div>
  </div>
</section>

<script>
  import { toPng, toBlob } from 'html-to-image';
  import jsPDF from 'jspdf';

  document.addEventListener('DOMContentLoaded', () => {
    const downloadPDF = document.getElementById('downloadPDF') as HTMLButtonElement;
    const downloadPNG = document.getElementById('downloadPNG') as HTMLButtonElement;
    const copyContact = document.getElementById('copyContact') as HTMLButtonElement;
    const pdfText = document.getElementById('pdfText') as HTMLSpanElement;
    const pngText = document.getElementById('pngText') as HTMLSpanElement;
    const copyText = document.getElementById('copyText') as HTMLSpanElement;

    // Función para descargar como PDF
    downloadPDF?.addEventListener('click', async () => {
      try {
        downloadPDF.disabled = true;
        pdfText.textContent = '⏳ Generando...';

        const element = document.getElementById('businessCard') as HTMLElement;
        if (!element) {
          throw new Error('No se encontró el elemento');
        }

        // Clonar elemento para no afectar el original
        const clone = element.cloneNode(true) as HTMLElement;
        
        // Reemplazar emojis con texto más grande
        const replaceEmojis = (node: HTMLElement) => {
          const walker = document.createTreeWalker(
            node,
            NodeFilter.SHOW_TEXT,
            null
          );
          
          const textNodes: Text[] = [];
          let currentNode;
          
          while (currentNode = walker.nextNode()) {
            textNodes.push(currentNode as Text);
          }
          
          textNodes.forEach((textNode) => {
            const text = textNode.textContent || '';
            if (/[\u{1F300}-\u{1F9FF}]|[\u{2600}-\u{26FF}]|[\u{2700}-\u{27BF}]/u.test(text)) {
              const span = document.createElement('span');
              span.textContent = text;
              span.style.fontSize = '1.2em';
              span.style.fontFamily = '"Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", sans-serif';
              span.style.display = 'inline-block';
              textNode.parentNode?.replaceChild(span, textNode);
            }
          });
        };
        
        replaceEmojis(clone);
        
        // Crear contenedor temporal
        const tempContainer = document.createElement('div');
        tempContainer.style.position = 'fixed';
        tempContainer.style.left = '-9999px';
        tempContainer.style.width = element.offsetWidth + 'px';
        tempContainer.appendChild(clone);
        document.body.appendChild(tempContainer);

        await new Promise(resolve => setTimeout(resolve, 200));

        // Generar imagen PNG con html-to-image (soporta oklch)
        const dataUrl = await toPng(clone, {
          quality: 1,
          pixelRatio: 4,
          backgroundColor: '#18181b',
          cacheBust: true,
          skipFonts: false,
          preferredFontFormat: 'woff2'
        });
        
        document.body.removeChild(tempContainer);

        // Crear PDF en formato tarjeta de presentación
        const pdf = new jsPDF({
          orientation: 'landscape',
          unit: 'mm',
          format: [85.6, 54]
        });

        pdf.addImage(dataUrl, 'PNG', 0, 0, 85.6, 54);
        pdf.save('Tarjeta-Benjamin-Espinoza.pdf');

        pdfText.textContent = '✅ Descargado';
        setTimeout(() => {
          pdfText.textContent = '📥 PDF';
          downloadPDF.disabled = false;
        }, 2000);
      } catch (error) {
        console.error('Error al generar PDF:', error);
        alert('Error al generar PDF: ' + (error as Error).message);
        pdfText.textContent = '❌ Error';
        setTimeout(() => {
          pdfText.textContent = '📥 PDF';
          downloadPDF.disabled = false;
        }, 2000);
      }
    });

    // Función para descargar como PNG
    downloadPNG?.addEventListener('click', async () => {
      try {
        downloadPNG.disabled = true;
        pngText.textContent = '⏳ Generando...';

        const element = document.getElementById('businessCard') as HTMLElement;
        if (!element) {
          throw new Error('No se encontró el elemento');
        }

        // Clonar elemento para no afectar el original
        const clone = element.cloneNode(true) as HTMLElement;
        
        // Reemplazar emojis con texto más grande
        const replaceEmojis = (node: HTMLElement) => {
          const walker = document.createTreeWalker(
            node,
            NodeFilter.SHOW_TEXT,
            null
          );
          
          const textNodes: Text[] = [];
          let currentNode;
          
          while (currentNode = walker.nextNode()) {
            textNodes.push(currentNode as Text);
          }
          
          textNodes.forEach((textNode) => {
            const text = textNode.textContent || '';
            if (/[\u{1F300}-\u{1F9FF}]|[\u{2600}-\u{26FF}]|[\u{2700}-\u{27BF}]/u.test(text)) {
              const span = document.createElement('span');
              span.textContent = text;
              span.style.fontSize = '1.2em';
              span.style.fontFamily = '"Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", sans-serif';
              span.style.display = 'inline-block';
              textNode.parentNode?.replaceChild(span, textNode);
            }
          });
        };
        
        replaceEmojis(clone);
        
        // Crear contenedor temporal
        const tempContainer = document.createElement('div');
        tempContainer.style.position = 'fixed';
        tempContainer.style.left = '-9999px';
        tempContainer.style.width = element.offsetWidth + 'px';
        tempContainer.appendChild(clone);
        document.body.appendChild(tempContainer);

        await new Promise(resolve => setTimeout(resolve, 200));

        // Generar blob PNG con html-to-image (soporta oklch)
        const blob = await toBlob(clone, {
          quality: 1,
          pixelRatio: 4,
          backgroundColor: '#18181b',
          cacheBust: true,
          skipFonts: false,
          preferredFontFormat: 'woff2'
        });
        
        document.body.removeChild(tempContainer);

        if (blob) {
          const url = URL.createObjectURL(blob);
          const link = document.createElement('a');
          link.download = 'Tarjeta-Benjamin-Espinoza.png';
          link.href = url;
          link.click();
          URL.revokeObjectURL(url);

          pngText.textContent = '✅ Descargado';
          setTimeout(() => {
            pngText.textContent = '🖼️ PNG';
            downloadPNG.disabled = false;
          }, 2000);
        }
      } catch (error) {
        console.error('Error al generar PNG:', error);
        alert('Error al generar PNG: ' + (error as Error).message);
        pngText.textContent = '❌ Error';
        setTimeout(() => {
          pngText.textContent = '🖼️ PNG';
          downloadPNG.disabled = false;
        }, 2000);
      }
    });

    // Función para copiar información al portapapeles
    copyContact?.addEventListener('click', async () => {
      const contactInfo = `Benjamin Espinoza
Full Stack Developer
📧 benjamintwo2002@gmail.com
📱 +56948553479
🔗 https://github.com/BenjaminEspinozaFK
🔗 https://www.linkedin.com/in/benjamin-espinoza-52b3a6375/`;

      try {
        await navigator.clipboard.writeText(contactInfo);
        copyText.textContent = '✅ Copiado';
        setTimeout(() => {
          copyText.textContent = '📋 Copiar';
        }, 2000);
      } catch (err) {
        console.error('Error al copiar:', err);
        alert('Error al copiar. Por favor, intenta nuevamente.');
        copyText.textContent = '❌ Error';
        setTimeout(() => {
          copyText.textContent = '📋 Copiar';
        }, 2000);
      }
    });
  });
</script>
</Layout>
